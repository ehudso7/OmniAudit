# OmniAudit Frontend Environment Configuration
# Copy this file to .env.local for local development

# Backend API URL — controls which backend the frontend talks to
#
# LOCAL DEV (Python backend on localhost):
VITE_API_URL=http://localhost:8000
#
# PRODUCTION (Python backend deployed separately):
# VITE_API_URL=https://api.omniaudit.example.com
#
# VERCEL DEMO MODE (no Python backend — only health/skills/analyze work):
# VITE_API_URL=
