{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "cd frontend && pnpm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
